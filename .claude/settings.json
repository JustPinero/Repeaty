{
  "$comment": "Hooks are deterministic enforcement. Valid event names: PreToolUse, PostToolUse, PostToolUseFailure, PostCompact, Stop, StopFailure, Notification, UserPromptSubmit, SubagentStart, SubagentStop, TaskCreated, TaskCompleted, TeammateIdle, WorktreeCreate, WorktreeRemove. Invalid names fail silently.",
  "hooks": {
    "PostCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "cat CLAUDE.md .claude/handoff.md audits/debt.md 2>/dev/null || true"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/pre-commit-secret-check.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/post-edit-format.sh \"$CLAUDE_TOOL_FILE_PATH\""
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/post-edit-a11y.sh \"$CLAUDE_TOOL_FILE_PATH\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash scripts/hooks/verify-working-state.sh"
          }
        ]
      }
    ]
  }
}
