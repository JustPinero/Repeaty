# Repeaty env vars — never commit a filled .env. Copy this to .env.local for the web app
# and use `supabase secrets set` for Edge Function secrets (see references/env-vars.md).

# ─── Client-exposed (build-time, baked into JS bundle) ────────────────────────
# Anything VITE_-prefixed ends up in the browser bundle. Never put a secret here.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key   # Public; RLS protects all data

# ─── Server-only (Edge Functions / local supabase CLI) ────────────────────────
# These MUST NOT be prefixed with VITE_. Set in production with:
#   supabase secrets set OPENAI_API_KEY=... ANTHROPIC_API_KEY=... SUPABASE_SERVICE_ROLE_KEY=...
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # Server-only, full DB access
OPENAI_API_KEY=sk-...                              # Whisper (score-pronunciation)
ANTHROPIC_API_KEY=sk-ant-...                       # Claude (generate-lesson, generate-feedback)
